    {
      "name": "Async Job",
      "item": [
        {
          "name": "customer_ticket_create_async",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('async job accepted', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.result.content.status).to.eql('PENDING');",
                  "  pm.environment.set('JOB_ID', body.result.content.jobId);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Api-Key",
                "value": "{{ADVISOR_API_KEY}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": \"async-create-1\",\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"customer_ticket_create_async\",\n    \"arguments\": {\n      \"customerId\": \"CUST-1001\",\n      \"title\": \"Mock title\",\n      \"description\": \"Mock description\"\n    }\n  }\n}"
            },
            "url": "{{MCP_BASE_URL}}/mcp",
            "description": "비동기 상담 티켓 생성을 접수합니다. 응답의 `jobId`는 `JOB_ID` 환경 변수에 자동 저장됩니다."
          }
        },
        {
          "name": "async_job_status",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Api-Key",
                "value": "{{USER_API_KEY}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": \"async-status-1\",\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"async_job_status\",\n    \"arguments\": {\n      \"jobId\": \"{{JOB_ID}}\"\n    }\n  }\n}"
            },
            "url": "{{MCP_BASE_URL}}/mcp",
            "description": "`customer_ticket_create_async`에서 저장된 `JOB_ID`로 작업 상태를 조회합니다."
          }
        }
      ]
